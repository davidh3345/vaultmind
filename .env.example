# ── VaultMind env (group stage, 0G Galileo TESTNET) ───────────────────────────
# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.
#
# Without these, the app runs in LOCAL DEV MODE (a clear banner shows) so you can
# test the full UX offline. For the Zero Cup eligibility gate you MUST run with
# real values so 0G does real work and the demo matches the code.

# 1) OPERATOR WALLET (server-side) — signs 0G Storage uploads (ciphertext only).
#    Generate one with:  npm run gen-operator
#    Then fund its address at https://faucet.0g.ai (0.1 0G/day).
OPERATOR_PRIVATE_KEY=

# 2) 0G STORAGE (testnet, Turbo network)
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# 3) 0G COMPUTE ROUTER (server-side) — create the key in the 0G Dashboard
#    (https://pc.testnet.0g.ai → API Keys → "inference" permission). Format: sk-...
ZG_ROUTER_API_KEY=
ZG_ROUTER_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
# Pick a live chatbot model from GET /v1/models. On testnet: qwen2.5-omni
ZG_ROUTER_MODEL=qwen2.5-omni

# Public — shown in the UI badge
NEXT_PUBLIC_OG_NETWORK=galileo-testnet
